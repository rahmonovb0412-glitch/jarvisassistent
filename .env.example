# ── Google Gemini AI (MAJBURIY) ──────────
# https://aistudio.google.com/app/apikey dan bepul oling
GEMINI_API_KEY=AIza...your-key-here...

# ── Server sozlamalari ───────────────────
PORT=8000
WORKSPACE_DIR=./workspace

# ── Telegram (IXTIYORIY) ─────────────────
# https://my.telegram.org/apps dan oling
# 1. my.telegram.org ga kiring
# 2. "API development tools" ga bosing
# 3. App yarating → api_id va api_hash oling
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+998901234567
